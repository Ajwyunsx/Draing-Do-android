  - id: orb
    text: "\u741A\u6B12\u59F1\u748B\u3223\uE63A\u59CA\u7248\u67A9\u9496\uE047\uE63D\u5A09?\u741A\u2544\u59F1\u745C\u5B2D\u59F1\u745C?"
  - id: sword
    text: "\u741A\uFE3D\uE76B\u745C?"
  - id: pickaxe
    text: "\u741A\uFF46\u5672\u745C\u590B\u90F4\u95AD?"
