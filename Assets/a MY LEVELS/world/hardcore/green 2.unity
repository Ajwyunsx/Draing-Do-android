  - id: Kimono
    text: "\u741A\uFF46\u5672\u705E\u6223\u59F1\u9496\uE047\u59F1"
  - id: Dragon Cloth
    text: "\u741A\u3125\u5553\u59CA\u677F\u5D4F\u9350\u6B13\u5051 \u741A\u6D9C\uE62E\u95AD\uE045\u90F4\u947A\uE21D\u67C2\u95AD?"
  - id: Dark Cloth
    text: "\u701B\u6FC7\uE76B\u705E\u6223\u67C2\u95AD\uE047\uE644 \u741A\u3125\u5553\u59CA\u677F\u5D4F\u9350\u6B13\u5051"
  - id: Far East Cloth
    text: "\u741A\u3125\u5553\u59CA\u677F\u5D4F\u9350\u6B13\u5051 \u741A\u6B12\u59F1\u745C\u5B2D\uE631\u947A\uE21B\u90F4\u95AD?"
  - id: Knight Cloth
    text: "\u741A\uE047\uE63D\u745C\u6226\u5051\u745C\u590E\uE630\u5A09\u5A5A\u5051\u745C?\u741A\u3125\u5553\u59CA\u677F\u5D4F\u9350\u6B13\u5051"
  - id: Monk Cloth
    text: "\u741A\u3125\u5553\u59CA\u677F\u5D4F\u9350\u6B13\u5051 \u741A\uFE41\u59F1\u9496\uE048\u5051\u745C\u5FDB\u5051"
  - id: Ninja Cloth
    text: "\u741A\u3125\u5553\u59CA\u677F\u5D4F\u9350\u6B13\u5051 \u741A\u0444\u5672\u9496\uE044\u5553\u951C\u7845\uE644"
  - id: bold
    text: "\u741A\u30E8\uE63D\u745C\u5B2D\uE63D\u5A09?"
  - id: hair_shaolin
    text: "\u741A\uFE41\u59F1\u9496\uE048\u5051\u745C?\u59A4\u65C8\u5051\u947A\uE21D\u963F\u93B3\u5823\u67C2\u745C?"
  - id: hair1
    text: "\u741A\u6B12\u59F1\u748B\u3223\u59F1\u745C\u5B2D\uE63D 1"
  - id: hair2
    text: "\u741A\u6B12\u59F1\u748B\u3223\u59F1\u745C\u5B2D\uE63D 2"
  - id: hair3
    text: "\u741A\u6B12\u59F1\u748B\u3223\u59F1\u745C\u5B2D\uE63D 3"
  - id: hair4
    text: "\u741A\u6B12\u59F1\u748B\u3223\u59F1\u745C\u5B2D\uE63D 4"
  - id: hair5
    text: "\u741A\u6B12\u59F1\u748B\u3223\u59F1\u745C\u5B2D\uE63D 5"
  - id: hair6
    text: "\u741A\u6B12\u59F1\u748B\u3223\u59F1\u745C\u5B2D\uE63D 6"
  - id: hair7
    text: "\u741A\u6B12\u59F1\u748B\u3223\u59F1\u745C\u5B2D\uE63D 7"
  - id: hair8
