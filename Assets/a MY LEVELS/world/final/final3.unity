  - id: Delete?
    text: Delete?
  - id: Resolution
    text: Resolution
  - id: Fullscreen
    text: Fullscreen
  - id: Begin Mission?
    text: Begin Mission?
  - id: Want Build Level?
    text: "\u935F\u6B4C\u59F1\u745C\u65C0\uE76B\u745C\u66E1\uE641 \u95BF\u5C83\u59F1\u745C\u5B2D\uE631\u745C\u590E\u59F1\u93B3\u5823\uE631\u745C?\u9496\uE047\u59F1\u9473\u4F7D\uE63D\u5A09?\u745C\u5D88\uE62E\u947A\uE21D\u510A\u59CA\u62CC\u67C2\u745C?\u745C\u6FCA\uE631\u947A\uE21D\u76AD\u947A?\u951C\u7470\u5553\u95AD\uE047\u67C2\u93B3\u5823\uE644?"
  - id: 'Experience:'
    text: 'Experience:'
  - id: Apply
    text: Apply
  - id: Magic Shop
    text: Magic Shop
  - id: Change Color
    text: Change Color
  - id: Barber Shop
    text: Barber Shop
  - id: Weapon Shop
    text: Weapon Shop
  - id: Cloth Shop
    text: Cloth Shop
  - id: Cancel
    text: Cancel
  - id: Empty Room
    text: Empty Room
  - id: Result
    text: Result
  - id: Enemy
    text: Enemy
  - id: Gold
    text: Gold
  - id: Time
    text: Time
  - id: Room Build
    text: Room Build
  TText:
  - id: Monday
    text: "\u741A\u2544\u59F1\u9496\uE045\uE76B\u9350\u6B10\uE76B\u748B\u3223\uE641\u9496\uE045\u5672\u5A09?"
  - id: Tuesday
    text: "\u741A\u6B12\uE631\u947A\uE21D\uE62E\u9496\uE045\u5672\u5A09?"
  - id: Wednesday
    text: "\u704F\u5FDA\uE62E\u59CA\u677F\u5553\u95AD?"
  - id: Thursday
    text: "\u93C1\u581F\uE76B\u745C\u5C83\u510A\u59CA\u62CC\uE62E\u748B?"
  - id: Friday
    text: "\u741A\u2544\uE644\u745C\u5C83\u67C2\u93B3\u5823\uE636\u95AD?"
  - id: Saturday
    text: "\u704F\u5FDA\uE632\u93C2\u6EC4\u67A9\u947A\uE21D\uE631\u95AD?"
  - id: Sunday
    text: "\u741A\u6B12\u59F1\u745C\u5B2B\u90F4\u745C\u590B\uE76B\u745C\u5B2B\uE76B\u9496\uE047\uE641\u59CA?"
  - id: Progress
    text: "\u741A\u2544\uE62E\u947A\uE21D\u76AD\u745C\u590B\uE76B\u745C\u5B2D\uE630:"
  - id: Power
    text: "\u704F\u5FD4\u5672\u748B\u3224\u5051"
  - id: select tool to upgrade
    text: "\u741A\u6B12\uE63D\u93C2\u6EC4\uE76B\u745C\u590B\u5672 \u95BF\u5C83\uE62E\u59CA\u677F\u5553\u705E\u621E\uE76B\u745C?
      \u745C\u65C7\uE631\u947A\uE21B\u67A9\u745C?\u745C\u5D88\u963F\u745C\u5D88\uE639\u745C\u66DF\u5672\u745C\u5C83\uE641"
  - id: 
    text: 
  - id: 
    text: 
  - id: 
    text: 
  - id: 
    text: 
  - id: 
    text: 
  - id: 
    text: 
  - id: 
    text: 
  - id: 
    text: 
  - id: 
    text: 
  - id: orb
    text: "\u741A\u6B12\u59F1\u748B\u3223\uE63A\u59CA\u7248\u67A9\u9496\uE047\uE63D\u5A09?\u741A\u2544\u59F1\u745C\u5B2D\u59F1\u745C?"
  - id: sword
    text: "\u741A\uFE3D\uE76B\u745C?"
  - id: pickaxe
    text: "\u741A\uFF46\u5672\u745C\u590B\u90F4\u95AD?"
  - id: 
    text: 
  - id: 
    text: 
  - id: 
    text: 
  - id: 
    text: 
  - id: 
    text: 
  - id: 
    text: 
  - id: 
    text: 
  - id: 
