  - id: LEVEL UP!
    text: LEVEL UP!
  - id: Achievement
    text: Achievement
  - id: gold 1000
    text: "\u741A\u71BC\u5051\u745C\u5910\u5051\u93C2\u6EC6\u59F1\u745C\u5C84\u5051\u5A09?1000
      \u951C\u7845\u59F1\u748B\u3223\u59F1\u745C\u5C84\u5051."
  - id: gold 1000 B
    text: "\u741A\u2544\u59F1\u748B\u3223\uE632\u745C\u65C0\u5672 +100 \u951C\u7845\u59F1\u748B\u3223\u59F1\u745C\u5C84\u5051
      \u9473?\u95BF\u5C83\u59F1\u9350\u6B13\u5051\u745C\u590E\u59F1\u5A09?"
  - id: gold 10000
    text: "\u741A\u71BC\u5051\u745C\u5910\u5051\u93C2\u6EC6\u59F1\u745C\u5C84\u5051\u5A09?10000
      \u951C\u7845\u59F1\u748B\u3223\u59F1\u745C\u5C84\u5051"
  - id: gold 10000 B
    text: "\u741A\u2544\u59F1\u748B\u3223\uE632\u745C\u65C0\u5672 +1000 \u951C\u7845\u59F1\u748B\u3223\u59F1\u745C\u5C84\u5051
      \u9473?\u95BF\u5C83\u59F1\u9350\u6B13\u5051\u745C\u590E\u59F1\u5A09?"
  - id: gold 100000
    text: "\u741A\u71BC\u5051\u745C\u5910\u5051\u93C2\u6EC6\u59F1\u745C\u5C84\u5051\u5A09?100000
      \u951C\u7845\u59F1\u748B\u3223\u59F1\u745C\u5C84\u5051"
  - id: gold 100000 B
    text: "\u741A\u2544\u59F1\u748B\u3223\uE632\u745C\u65C0\u5672 +10000 \u951C\u7845\u59F1\u748B\u3223\u59F1\u745C\u5C84\u5051
      \u9473?\u95BF\u5C83\u59F1\u9350\u6B13\u5051\u745C\u590E\u59F1\u5A09?"
  - id: gold 1000000
    text: "\u741A\u71BC\u5051\u745C\u5910\u5051\u93C2\u6EC6\u59F1\u745C\u5C84\u5051\u5A09?1000000
      \u951C\u7845\u59F1\u748B\u3223\u59F1\u745C\u5C84\u5051"
  - id: gold 1000000 B
    text: "\u741A\u2544\u59F1\u748B\u3223\uE632\u745C\u65C0\u5672 +100000 \u951C\u7845\u59F1\u748B\u3223\u59F1\u745C\u5C84\u5051
      \u9473?\u95BF\u5C83\u59F1\u9350\u6B13\u5051\u745C\u590E\u59F1\u5A09?"
  TMessage:
  - id: kill
    text: "\u741A\u2544\u59F1\u93C2\u6EC4\uE76B\u5A09?\u9473\u4F7D\uE630\u59CA\u62CC\uE634
      \u9473\u4F7D\uE62E\u95AD\uE047\u76AD\u947A\uE21D\u510A!"
  - id: Return to castle!
    text: "\u741A\u6B12\u59F1\u951C\u7845\u510A\u745C\u5910\u5051\u745C\u682D\u5051\u5A09\u52EE\uE630\u745C?\u9473?\u951C\u5F52\u5051\u705E\u6223\u59F1\u5A09?"
  - id: get new mission
    text: "\u741A\u6B12\u59F1\u951C\u7845\uE641\u705E\u621E\u5672 \u9496\uE047\u59F1\u9473\u4F7D\uE632\u745C?\u705E\u621E\u5672\u745C\u5B2D\uE630\u93B3\u5823\uE643!/\u741A\u72BA\u963F\u93B3?\u9350\u6B10\uE76B\u748B\u3224\u5051\u5A09?
      \u745C\u65C7\uE631\u947A?\u745C\u5FDA\u59F1\u745C\u65C0\uE76B\u745C\u66E1\uE641!"
  - id: count
    text: "\u741A\uFF48\u59F1\u748B\u3221\u5672\u745C\u65C0\uE76B\u745C\u5B2D\uE631\u9473\u4F7D\u59F1:"
  TMission:
  - id: mission1
    text: "\u741A\u2544\uE62E\u93B3\u5823\u67C2\u745C?\u9496\uE048\u5051\u705E?\u9496\uE047\uE632\u9357\u6B4C\u67C2\u95AD\uE047\uE644
      \u745C\u5C83\u510A\u947A\uE21D\uE644 \u95BF\u5C83\u59F1\u705E\u6223\u59F1\u745C\u682C\uE641!/\u741A\u6D99\uE76B\u705E\u6223\u59F1\u9496\uE047\uE63D
      \u95AD\uE047\uE631\u95AD\uE045\u90F4\u745C\u5D88\uE643\u745C?\u9496\uE048\u5051\u745C?\u745C\u5B2D\u510A\u745C\u71BB\uE63B\u59CA\u62CC\u67C2\u9496\uE047\uE63D\u5A09?\u947A\uE21D\uE630\u745C\u5C83\uE62E\u947A\uE21D\u510A!/\u741A\u2544\u59F1\u93C2\u6EC4\uE76B\u9350\u6B10\u5672
      \u9473\u4F7D\uE630\u59CA\u62CC\uE634 \u9473\u4F7D\uE62E\u95AD\uE047\u76AD\u947A\uE21D\u510A,
      \u745C\u5B2E\u6532\u95AD\uE047\uE630\u93B3?\u95BF\u5C83\uE62E\u93B3\u5823\u67C2\u745C\u621E\uE76B\u745C\u5B2D\uE630\u745C?/\u745C\u5B2D\u67C2\u93B3\u5823\u717F\u745C?\u9496\uE048\u5051\u748B\u3223\u59F1\u748B\u612D\u5672,
      \u95BF\u5C83\u59F1\u705E\u6223\u59F1\u748B\u612D\u5672 \u745C\u5B2D\u59F1\u93C2\u6EC6\uE62E\u95AD\uE047\uE631\u745C?\u745C\u5D88\uE62E\u947A\uE21A\u5D4F\u95AD\uE045\u7860,/\u95BF\u5C83\uE62E\u93B3\u581D\u7749\u93B3?\u745C\u590E\u59F1\u9350\u6B12\uE63D
      \u93B3?\u95BF\u5C83\u59F1\u748B\u3221\uE76B\u5A09?\u745C\u6223\u510A\u59CA\u62CC\uE631\u745C?"
  TTalk:
  - id: Build a New Level?
    text: "\u93BC?\u705E\u6223\u59F1\u748B\u612F\uE632 \u95BF\u5C83\u59F1\u745C\u5B2D\uE631\u745C\u590E\u59F1\u93B3\u5823\uE631\u745C?\u59CA\u62CC\uE63B\u59CA?\u947A\uE21A\u5553\u93B3\u5823\u67C2
      \u745C\u6FCA\uE631\u95AD\uE044\u5D4F \u745C\u6FCA\uE631\u947A\uE21A\u7749\u745C?\u951C\u7470\u5553\u95AD\uE047\u67C2\u93B3\u5823\uE643./\u7ED7\u621E\uE76B\u9496\uE048\u5051
      \u95BF\u5C83\u59F1\u745C\u5B2D\uE631\u745C\u590E\u59F1\u5A09\u52EC\u90F4\u93B3?"
  - id: 
