  TText:
  - id: Monday
    text: "\u741A\u2544\u59F1\u9496\uE045\uE76B\u9350\u6B10\uE76B\u748B\u3223\uE641\u9496\uE045\u5672\u5A09?"
  - id: Tuesday
    text: "\u741A\u6B12\uE631\u947A\uE21D\uE62E\u9496\uE045\u5672\u5A09?"
  - id: Wednesday
    text: "\u704F\u5FDA\uE62E\u59CA\u677F\u5553\u95AD?"
  - id: Thursday
    text: "\u93C1\u581F\uE76B\u745C\u5C83\u510A\u59CA\u62CC\uE62E\u748B?"
  - id: Friday
    text: "\u741A\u2544\uE644\u745C\u5C83\u67C2\u93B3\u5823\uE636\u95AD?"
  - id: Saturday
    text: "\u704F\u5FDA\uE632\u93C2\u6EC4\u67A9\u947A\uE21D\uE631\u95AD?"
  - id: Sunday
    text: "\u741A\u6B12\u59F1\u745C\u5B2B\u90F4\u745C\u590B\uE76B\u745C\u5B2B\uE76B\u9496\uE047\uE641\u59CA?"
  - id: Progress
    text: "\u741A\u2544\uE62E\u947A\uE21D\u76AD\u745C\u590B\uE76B\u745C\u5B2D\uE630:"
  - id: Power
    text: "\u704F\u5FD4\u5672\u748B\u3224\u5051"
  - id: select tool to upgrade
    text: "\u741A\u6B12\uE63D\u93C2\u6EC4\uE76B\u745C\u590B\u5672 \u95BF\u5C83\uE62E\u59CA\u677F\u5553\u705E\u621E\uE76B\u745C?
      \u745C\u65C7\uE631\u947A\uE21B\u67A9\u745C?\u745C\u5D88\u963F\u745C\u5D88\uE639\u745C\u66DF\u5672\u745C\u5C83\uE641"
