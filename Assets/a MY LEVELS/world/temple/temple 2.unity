  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 61e4f25df2be4507e602d5a54170f83b, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  TMenu:
  - id: Achievements
    text: Achievements
  - id: 'Lvl:'
    text: 'Level:'
  - id: 'Health:'
    text: 'Health:'
  - id: 'Magic:'
    text: 'Magic:'
  - id: Player
    text: Player
  - id: 'Players:'
